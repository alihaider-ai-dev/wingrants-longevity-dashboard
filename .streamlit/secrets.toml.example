# Template — copy to `.streamlit/secrets.toml` for local development OR
# paste these keys into the Streamlit Cloud "Secrets" textbox for the
# deployed app. NEVER commit secrets.toml itself (covered by .gitignore).

# Single shared password for the dashboard. Put it through `st.secrets`
# so it's never in source.
app_password = "REPLACE_ME_with_a_long_random_string"

# Postgres connection string for the READ-ONLY user. Create with:
#   CREATE USER wg_dashboard_ro WITH PASSWORD '...';
#   GRANT CONNECT ON DATABASE wingrants TO wg_dashboard_ro;
#   GRANT USAGE ON SCHEMA public TO wg_dashboard_ro;
#   GRANT SELECT ON
#     concept_notes, concept_note_scores, concept_note_score_summaries,
#     strategy_notes, strategy_note_scores, strategy_note_score_summaries,
#     proposals, proposal_scores, proposal_score_summaries,
#     proposal_scorecards, scorecard_scores, scorecard_summaries,
#     consortiums, clusters, users
#   TO wg_dashboard_ro;
# Then whitelist Streamlit Cloud's outbound IPs on the RDS security
# group (see README.md "DB connectivity" section for the current
# range — Streamlit Cloud publishes this on their docs).
db_url = "postgresql://wg_dashboard_ro:REPLACE_ME@host.eu-central-1.rds.amazonaws.com:5432/wingrants?sslmode=require"

# S3 access for the consortium overall_score JSONB blobs. Read-only
# credentials. Same `wingrants-results` bucket the main app writes to.
aws_access_key_id = "REPLACE_ME"
aws_secret_access_key = "REPLACE_ME"
aws_region = "eu-central-1"
aws_s3_bucket = "wingrants-results"
